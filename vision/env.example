# ── Local inference (default) ─────────────────────────────────────────────
# In-process on the Jetson / PC (no cloud round-trip). First run may download weights.
export VISION_RUNTIME=embedded
export ROBOFLOW_MODEL_ID=your-workspace/window-buttons/1
# Private / workspace models: required once for download
export ROBOFLOW_API_KEY=

# ── HTTP to a local Inference Server instead ────────────────────────────────
# export VISION_RUNTIME=http
# export ROBOFLOW_API_URL=http://127.0.0.1:9001
# Start server:  inference server start   (see Roboflow Inference docs)

# ── Roboflow Cloud (not local) ─────────────────────────────────────────────
# export VISION_RUNTIME=http
# export ROBOFLOW_API_URL=https://serverless.roboflow.com
# export ROBOFLOW_API_KEY=...

# USB camera index (gripper cam — first index used by window_servo)
export CARBOT_VISION_CAMERAS=0
# Jetson CSI / NVMM: full GStreamer pipeline (overrides index when set)
# Nano/NX/Orin — adjust sensor-id, resolution, flip-method for your module:
# export CARBOT_VISION_GSTREAMER='nvarguscamerasrc sensor-id=0 ! video/x-raw(memory:NVMM),width=1280,height=720,framerate=30/1 ! nvvidconv flip-method=0 ! video/x-raw,format=BGRx ! videoconvert ! video/x-raw,format=BGR ! appsink drop=1'

export VISION_CONFIDENCE=0.4
export VISION_INFER_INTERVAL_SEC=0.5
# export VISION_LABEL_ALLOWLIST=window_up,window_down

# Dev
# export VISION_MOCK=1

export VISION_SERVER_HOST=0.0.0.0
export VISION_SERVER_PORT=5001

# ── Gripper camera: search + visual track (needs motion_server on :5000) ──
# python -m vision.window_servo --preview
# Browser: http://<jetson-ip>:8080/
export MOTION_HOST=127.0.0.1
export MOTION_PORT=5000
export VISION_PREVIEW_HOST=0.0.0.0
export VISION_PREVIEW_PORT=8080
export VISION_PREVIEW_JPEG_QUALITY=75
# Pan/tilt = relative servo IDs (carbot defaults 6,7)
export VISION_PAN_SERVO=6
export VISION_TILT_SERVO=7
export VISION_SEARCH_STEP=90
export VISION_SEARCH_SPEED=200
export VISION_TRACK_SPEED=180
export VISION_KP_X=0.35
export VISION_KP_Y=0.35
# If arm moves opposite to error, set to 1
# export VISION_INVERT_PAN=1
# export VISION_INVERT_TILT=1
export VISION_MAX_DELTA=140
export VISION_DEADZONE_PX=28
export VISION_LOST_FRAMES=10
# export VISION_FREEZE_ON_START=0
# Optional: small actuator pulses when target is big + centered (dangerous — tune)
# export VISION_APPROACH_ENABLE=1
# export VISION_APPROACH_AREA_FRAC=0.12
# export VISION_APPROACH_MM=3
