# BLDC / Pi UART — optional overrides for nina-link (stock defaults are already in nina-link.service).
# Match desktop/nina-ui-kiosk.service when your robot uses a non-default serial device or wiring.
#
#   sudo mkdir -p /etc/nina-link
#   sudo cp nina/systemd/nina-link-navigation.env.example /etc/nina-link/navigation.env
#   sudo systemctl restart nina-link
#
# nina-link.service: kiosk-matching NINA_NAV_* defaults first, then EnvironmentFile=-/etc/nina-link/navigation.env
# (the leading "-" means systemd ignores a missing file).

NINA_NAV_MODE=remote
NINA_NAV_REMOTE_PORT=/dev/ttyTHS1
NINA_NAV_REMOTE_BAUD=115200
NINA_NAV_INVERT_LEFT=1
NINA_NAV_INVERT_RIGHT=0
