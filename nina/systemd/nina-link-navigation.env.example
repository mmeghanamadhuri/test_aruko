# BLDC / Pi UART — keep in sync with Sirena UI kiosk
# (see desktop/nina-ui-kiosk.service). Install on the robot:
#
#   sudo mkdir -p /etc/nina-link
#   sudo cp nina/systemd/nina-link-navigation.env.example /etc/nina-link/navigation.env
#   sudo systemctl restart nina-link
#
# nina-link.service loads this file via EnvironmentFile=-/etc/nina-link/navigation.env
# (optional; the leading "-" means systemd ignores a missing file).

NINA_NAV_MODE=remote
NINA_NAV_REMOTE_PORT=/dev/ttyTHS1
NINA_NAV_REMOTE_BAUD=115200
NINA_NAV_INVERT_LEFT=1
NINA_NAV_INVERT_RIGHT=0
